# ===== MongoDB =====
# --- Local (mặc định) ---
MONGODB_URI=mongodb://localhost:27017/it_student_forum

# --- Cloud (MongoDB Atlas) - uncomment khi nâng cấp ---
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/it_student_forum?retryWrites=true&w=majority

# ===== Server =====
PORT=5000

# ===== JWT =====
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ===== Email (Nodemailer) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# ===== Client =====
CLIENT_URL=http://localhost:5173
